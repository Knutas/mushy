{
  "compilerOptions": {
    "target": "esnext",
    "rootDir": "src",
    "outDir": "dist",
    "types": [
      "leaflet",
      "leaflet-markercluster"
    ],
    "removeComments": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": true,
    "skipLibCheck": true
  }
}
